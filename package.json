{
  "name": "mcp-inspector",
  "version": "0.1.0",
  "description": "MCP client for discovering and exercising resources, tools, prompts, and completions over stdio or OAuth-protected HTTP. Ships with a CLI, an interactive REPL, and a web dashboard served by `mcp-inspector serve`.",
  "type": "module",
  "bin": {
    "mcp-inspector": "dist/cli.js",
    "mcpi": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "pnpm build:cli && pnpm build:web",
    "build:cli": "tsc",
    "build:web": "vite build",
    "dev": "tsx src/cli.ts",
    "dev:web": "vite",
    "serve": "node dist/cli.js serve",
    "start": "node dist/cli.js",
    "clean": "rm -rf dist web/node_modules/.vite",
    "prepublishOnly": "pnpm clean && pnpm build",
    "typecheck": "tsc --noEmit && tsc --noEmit -p web/tsconfig.app.json"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "cli",
    "client",
    "oauth",
    "inspector",
    "dashboard"
  ],
  "license": "MIT",
  "packageManager": "pnpm@10.24.0",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@programsmagic/toon-tokenizer": "^0.1.0",
    "commander": "^14.0.3",
    "open": "^11.0.0",
    "picocolors": "^1.1.1",
    "shell-quote": "^1.8.3"
  },
  "devDependencies": {
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/vite": "^4.1.13",
    "@types/node": "^25.6.0",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@types/shell-quote": "^1.7.5",
    "@vitejs/plugin-react": "^6.0.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "lucide-react": "^0.468.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-router-dom": "^7.14.2",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4.1.13",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.10"
  }
}
